# ── HuggingFace (needed for PyAnnote diarization model download) ──────────────
HF_TOKEN=your_huggingface_token_here

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cortexium

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Camera ────────────────────────────────────────────────────────────────────
# 0 = default webcam, or provide a video file path
CAMERA_SOURCE=0
# CAMERA_SOURCE=E:/videos/test.mp4

# ── Face Recognition ──────────────────────────────────────────────────────────
FACE_CONFIDENCE_THRESHOLD=0.6
FACE_RECOGNITION_MODEL=buffalo_l

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8765

# ── HUD ───────────────────────────────────────────────────────────────────────
HUD_WIDTH=1280
HUD_HEIGHT=720
HUD_FULLSCREEN=false
